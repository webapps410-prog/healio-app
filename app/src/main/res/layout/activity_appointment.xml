<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E53935"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvScreenTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Appointments"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </RelativeLayout>

    <!-- Filter Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:tabTextColor="#757575"
        app:tabSelectedTextColor="#E53935"
        app:tabIndicatorColor="#E53935"
        app:tabMode="fixed"
        app:tabGravity="fill" />

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvNoAppointments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No appointments found."
        android:textSize="15sp"
        android:textColor="#757575"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAppointments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- FAB for new appointment (patient only — hidden for doctors in code) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewAppointment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#E53935"
        app:tint="#FFFFFF"
        android:contentDescription="Book new appointment" />

</LinearLayout>