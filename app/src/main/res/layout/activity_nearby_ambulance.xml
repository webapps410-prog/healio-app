<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Full-screen map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top overlay bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚑 Nearby Ambulances"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLocationInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Getting location..."
            android:textSize="11sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvDriverCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Searching..."
            android:textSize="12sp"
            android:textColor="#FFD700"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Progress bar (centred) -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Bottom sheet — driver details -->
    <LinearLayout
        android:id="@+id/bottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="12dp"
        android:visibility="gone">

        <!-- Close row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvBSName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Driver Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#212121" />

            <Button
                android:id="@+id/btnBSClose"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:text="✕"
                android:textSize="14sp"
                android:padding="0dp"
                android:background="@android:color/transparent"
                android:textColor="#757575" />
        </RelativeLayout>

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvBSStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Info grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBSAmbulance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ambulance: —"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvBSPlace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 —"
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tvBSPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 —"
                    android:textSize="13sp"
                    android:textColor="#424242" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvBSDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📏 — km"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1976D2"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvBSETA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏱ ETA —"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#388E3C" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnBSCall"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="📞 CALL"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1976D2"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnBSBook"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="🚑 BOOK NOW"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E53935"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>