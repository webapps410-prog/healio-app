<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Healio"
        tools:targetApi="31">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Healio.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".SignInActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".RegistrationActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".PatientRegistrationActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".DoctorRegistrationActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AmbulanceDriverRegistrationActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".PatientDashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".DoctorDashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AmbulanceDriverDashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".DoctorListActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".DoctorConsultationActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AppointmentActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:label="My Appointments" />

        <activity
            android:name=".FirstAidVideosActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".NearbyAmbulanceActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".EmergencySOSActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".IncomingSOSActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Healio.FullScreen" />

        <!-- ✅ FIX: Added showWhenLocked, turnScreenOn, singleTop so alert
             appears on lock screen even when driver's phone is sleeping -->
        <activity
            android:name=".IncomingAmbulanceSOSActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:launchMode="singleTop"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Healio.FullScreen" />

        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".VideoCallActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".EmergencyMapActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <service
            android:name=".SOSRingtoneService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="phoneCall" />

        <service
            android:name=".SOSListenerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".PatientNotificationService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ✅ FIX: AmbulanceSOSListenerService was COMPLETELY MISSING from
             the manifest. Without this entry Android silently refuses to start
             the service on API 26+, so the driver never receives any alert.
             This is the PRIMARY reason the ambulance driver gets no notification. -->
        <service
            android:name=".AmbulanceSOSListenerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>